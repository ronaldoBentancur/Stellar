<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - StellarMinds</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Presentacion.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">🔭 StellarMinds</a>
                
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Inicio</a>
                        </li>

                        @if (Context.Session.GetString("rol") == null)
                        {
                            // Usuario sin loguear (RF01)
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-bold" asp-controller="Usuario" asp-action="Login"></a>
                            </li>
                        }

                        @if (Context.Session.GetString("rol") == "Socio")
                        {
                            // Navegadores exclusivos para los Socios
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Observacion" asp-action="Alta">Alta de Observación</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Prestamo" asp-action="MisPrestamos">Mis Préstamos</a>
                            </li>
                        }

                        @if (Context.Session.GetString("rol") == "Coordinador")
                        {
                            // Navegadores exclusivos para los Coordinadores
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Prestamo" asp-action="Alta">Nuevo Préstamo</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Prestamo" asp-action="Devolucion">Devolución de Equipos</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Prestamo" asp-action="PorTelescopio">Préstamos por Telescopio</a>
                            </li>
                        }

                        @if (Context.Session.GetString("rol") == "Administrador")
                        {
                            // Navegadores exclusivos para los Administradores
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Usuario" asp-action="Alta">AltaUsuario</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Equipo" asp-action="Index">Gestión de Equipos</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Prestamo" asp-action="PorTelescopio">Préstamos por Telescopio</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Prestamo" asp-action="Auditoria">Auditoría de Préstamos</a>
                            </li>
                        }

                        @if (Context.Session.GetString("rol") != null)
                        {
                            // Funcionalidades comunes para usuarios logueados
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="ObjetoCeleste" asp-action="Ranking">Ranking de Objetos</a>
                            </li>
                        }
                    </ul>

                    @if (Context.Session.GetString("rol") != null)
                    {
                        <ul class="navbar-nav">
                            <li class="nav-item">
                                <a class="nav-link text-danger fw-bold" asp-controller="Usuario" asp-action="Logout">Cerrar Sesión</a>
                            </li>
                        </ul>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Observatorio StellarMinds - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacidad</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>